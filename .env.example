# ============================================================
# Variables de Entorno - Inventario Mollie Aspen
# ============================================================
# Copia este archivo como .env para desarrollo local
# En Vercel, configura estas variables en Settings > Environment Variables

# REQUERIDO en producción: clave secreta para firmar tokens JWT
# Genera una clave segura con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cambia_esto_por_una_clave_segura_aleatoria

# Credenciales del primer admin (solo se usan en el PRIMER arranque si no hay usuarios)
ADMIN_USER1=bycarlos
ADMIN_PASS1=cambia_esta_contrasena

# Credenciales del segundo admin
ADMIN_USER2=adminjefe
ADMIN_PASS2=cambia_esta_contrasena_tambien

# Base de datos (Vercel Postgres / Neon / Supabase - dejar vacío para usar SQLite local)
# DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require
