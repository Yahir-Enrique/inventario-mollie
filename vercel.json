{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "index.css",
      "use": "@vercel/static"
    },
    {
      "src": "index.js",
      "use": "@vercel/static"
    },
    {
      "src": "usuarios.html",
      "use": "@vercel/static"
    },
    {
      "src": "usuarios.js",
      "use": "@vercel/static"
    },
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "dest": "/index.html"
    },
    {
      "src": "^/index\\.css$",
      "dest": "/index.css"
    },
    {
      "src": "^/index\\.js$",
      "dest": "/index.js"
    },
    {
      "src": "^/usuarios\\.html$",
      "dest": "/usuarios.html"
    },
    {
      "src": "^/usuarios\\.js$",
      "dest": "/usuarios.js"
    },
    {
      "src": "^/api/(.*)$",
      "dest": "/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}
